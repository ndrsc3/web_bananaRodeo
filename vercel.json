{
    "outputDirectory": "dist",
    "installCommand": "npm install",
    "devCommand": "vite --port $PORT",
    "buildCommand": "npm run build",
    "routes": [
        { "src": "/api/(.*)", "dest": "/api/$1" },
        { "handle": "filesystem" }
    ],
    "functions": {
        "api/*.ts": { "runtime": "@vercel/node@5.6.16" }
    }
}
